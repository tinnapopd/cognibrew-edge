# Cognibrew Edge – Environment Variables
# Copy to .env and customise as needed:
#   cp .env.example .env

# Logging (applies to all services)
LOG_LEVEL=INFO

# RabbitMQ
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# Inference Server
STREAM_SKIP_FRAME=5
STREAM_APPLY_DIFF=true
STREAM_DIFF_THRESHOLD=5.0
RABBITMQ_EXCHANGE_NAME=cognibrew.inference
RABBITMQ_QUEUE_NAME=cognibrew.inference.face_embedded
RABBITMQ_FACE_EMBEDDED_ROUTING_KEY=face.embedded
MODEL_FRAMEWORK=insightface
# Supported: antelopev2, buffalo_l, buffalo_m, buffalo_s, buffalo_sc
MODEL_NAME=buffalo_sc

# Recognition Service
RABBITMQ_INFERENCE_EXCHANGE_NAME=cognibrew.inference
RABBITMQ_INFERENCE_QUEUE_NAME=cognibrew.inference.face_embedded
RABBITMQ_FACE_RECOGNIZED_ROUTING_KEY=face.recognized
RABBITMQ_FACE_UPDATE_EXCHANGE_NAME=cognibrew.vectordb
RABBITMQ_FACE_UPDATE_QUEUE_NAME=cognibrew.vectordb.face_updated
RABBITMQ_FACE_UPDATE_ROUTING_KEY=face.updated
QDRANT_COLLECTION_NAME=face_embeddings
QDRANT_EMBEDDING_DIM=512
MODEL_SIMILARITY_THRESHOLD=0.65

# Version Manager
DOCKER_TARGET_LABEL=cognibrew.service=recognition
DOCKER_HEALTH_TIMEOUT_S=30
DOCKER_HEALTH_POLL_S=1
